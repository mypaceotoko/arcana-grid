# ARCANA GRID environment variables (example)
#
# Copy to `.env.local` and fill with your own Supabase project values.
# NEVER commit real keys. `.env*` is gitignored except this `.env.example`.

# --- Supabase (online match — NOT wired into the game yet) -------------------

# Public project URL. Safe to expose to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key. Safe to expose to the browser. RLS must protect all data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. SERVER-ONLY. Bypasses RLS.
# ⚠️ Do NOT prefix with NEXT_PUBLIC_ and never import it into client code.
# Only read it from server-side code (Route Handlers / Server Actions).
SUPABASE_SERVICE_ROLE_KEY=
