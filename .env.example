# ARCANA GRID local environment template
# Copy this file to .env.local and fill values after creating a Supabase project.
# Never commit .env.local or real secrets.

# Public Supabase values used by browser and SSR clients.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase admin key. Do not prefix with NEXT_PUBLIC_ and do not import
# the admin client from Client Components.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: enable debug-only pages/features in development when explicitly wired.
ENABLE_DEBUG_PAGES=false
